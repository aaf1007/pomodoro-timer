# Browser client (Supabase JS SDK via @supabase/ssr).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# FastAPI backend (supabase-py). Same values as above — the split is because
# NEXT_PUBLIC_* is exposed to the browser bundle and these are read server-side.
SUPABASE_URL=
SUPABASE_ANON_KEY=
